# Pacifica API configuration
PACIFICA_NETWORK=mainnet
PACIFICA_API_BASE_URL=https://api.pacifica.fi/api/v1
PACIFICA_API_KEY=
PACIFICA_API_TIMEOUT=10
PACIFICA_MAX_RETRIES=5

# Data storage
DATA_ROOT=../data
LOGS_ROOT=../logs
PARQUET_BUFFER_MAX_ROWS=5000
PARQUET_BUFFER_MAX_SECONDS=60
RETENTION_DAYS=30
ARCHIVE_ENABLED=false

# QuestDB connection
QUESTDB_HOST=localhost
QUESTDB_PORT=8812
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest

# Trading configuration
SYMBOLS=BTC,ETH
INITIAL_CAPITAL=10000.0
POSITION_SIZE_PCT=0.10
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.03
MAX_HOLD_SECONDS=180
MAX_DAILY_LOSS_PCT=0.05
MAX_DAILY_TRADES=50
MAX_CONSECUTIVE_LOSSES=5
MAX_TOTAL_EXPOSURE_PCT=0.50
MAX_CONCENTRATION_PCT=0.30
MIN_CONFIDENCE=0.5
MIN_SIGNALS_AGREE=2
REQUIRE_CVD=true
REQUIRE_TFI=true
REQUIRE_OFI=false

# Signal parameters
CVD_LOOKBACK_PERIODS=20
CVD_DIVERGENCE_THRESHOLD=0.15
TFI_WINDOW_SECONDS=60
TFI_SIGNAL_THRESHOLD=0.3
OFI_SIGNAL_THRESHOLD_SIGMA=2.0
ATR_PERIOD=14
ATR_THRESHOLD_MULTIPLIER=1.5
SPREAD_THRESHOLD_BPS=15
MIN_DEPTH_THRESHOLD=10.0
EXTREME_FUNDING_THRESHOLD=0.001

# Deployment
ENV=local
ENABLE_HEALTH_CHECKS=true
METRICS_ENDPOINT=
REGION=

# API service (optional for FastAPI apps)
API_HOST=0.0.0.0
API_PORT=8000
