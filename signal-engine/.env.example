PACIFICA_NETWORK=mainnet
PACIFICA_API_BASE_URL=https://api.pacifica.fi/api/v1
PACIFICA_API_TIMEOUT=10.0
# PACIFICA_API_KEY=

# QuestDB connection
QUESTDB_HOST=localhost
QUESTDB_PORT=8812
QUESTDB_USER=admin
QUESTDB_PASSWORD=quest

# Trading parameters
SYMBOLS=BTC,ETH
INITIAL_CAPITAL=10000.0
POSITION_SIZE_PCT=0.10
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.03
MAX_HOLD_SECONDS=180

# Risk management
MAX_DAILY_LOSS_PCT=0.05
MAX_DAILY_TRADES=50
MAX_CONSECUTIVE_LOSSES=5
MAX_TOTAL_EXPOSURE_PCT=0.50
MAX_CONCENTRATION_PCT=0.30

# Signal parameters
CVD_LOOKBACK_PERIODS=20
CVD_DIVERGENCE_THRESHOLD=0.15
TFI_WINDOW_SECONDS=60
TFI_SIGNAL_THRESHOLD=0.3
OFI_SIGNAL_THRESHOLD_SIGMA=2.0
MIN_CONFIDENCE=0.5
MIN_SIGNALS_AGREE=2
REQUIRE_CVD=true
REQUIRE_TFI=true
REQUIRE_OFI=false

# Regime detection
ATR_PERIOD=14
ATR_THRESHOLD_MULTIPLIER=1.5
SPREAD_THRESHOLD_BPS=15
MIN_DEPTH_THRESHOLD=10.0
EXTREME_FUNDING_THRESHOLD=0.001

# API
API_HOST=0.0.0.0
API_PORT=8000
