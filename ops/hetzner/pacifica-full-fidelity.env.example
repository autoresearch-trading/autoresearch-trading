# Pacifica full-fidelity Hetzner/systemd environment template.
# Copy to /etc/pacifica-full-fidelity.env on the Hetzner host and fill secret values there.
# Do not commit real credentials.

# Repo checkout on the host.
PACIFICA_REPO_DIR=/opt/pacifica-full-fidelity

# Attached Hetzner volume mount. This is a spool, not durable archive.
PACIFICA_SPOOL_MOUNT=/mnt/pacifica-spool
PACIFICA_FULL_FIDELITY_ROOT=/mnt/pacifica-spool/pacifica_full_fidelity
PACIFICA_FULL_FIDELITY_STATE_DB=/mnt/pacifica-spool/pacifica_full_fidelity_storage.sqlite
UV_CACHE_DIR=/mnt/pacifica-spool/.uv-cache

# Durable R2 target.
PACIFICA_FULL_FIDELITY_REMOTE_BASE=r2:pacifica-trading-data
PACIFICA_FULL_FIDELITY_R2_PREFIX=raw/pacifica/full_fidelity

# Local spool retention on Hetzner. Prune only remote-verified files.
PACIFICA_FULL_FIDELITY_RETENTION_DAYS=2
PACIFICA_R2_PRUNE_EXECUTE=1

# Collector safety/performance settings.
PACIFICA_FULL_FIDELITY_RAW_PAYLOAD_MODE=compact
PACIFICA_FULL_FIDELITY_MIN_FREE_DISK_GB=10
PACIFICA_FULL_FIDELITY_REST_SNAPSHOT_INTERVAL_S=60
PACIFICA_FULL_FIDELITY_SUBSCRIPTION_BATCH_SIZE=50
PACIFICA_FULL_FIDELITY_SUBSCRIPTION_DELAY_S=0.25
# Optional volume reductions; leave empty for all live symbols/default intervals.
# PACIFICA_FULL_FIDELITY_SYMBOLS=BTC,ETH,SOL
# PACIFICA_FULL_FIDELITY_INTERVALS=1m
# PACIFICA_FULL_FIDELITY_AGG_LEVELS=1
# PACIFICA_FULL_FIDELITY_NO_PRICES=1

# rclone Cloudflare R2 remote. Values below are placeholders.
RCLONE_CONFIG_R2_TYPE=s3
RCLONE_CONFIG_R2_PROVIDER=Cloudflare
RCLONE_CONFIG_R2_ACL=private
RCLONE_CONFIG_R2_NO_CHECK_BUCKET=true
RCLONE_CONFIG_R2_ACCESS_KEY_ID=[REDACTED]
RCLONE_CONFIG_R2_SECRET_ACCESS_KEY=[REDACTED]
RCLONE_CONFIG_R2_ENDPOINT=https://[REDACTED].r2.cloudflarestorage.com
